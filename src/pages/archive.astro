---
// Archive — Talking Around Fire
// Full-screen 5×4 grid. Dark background, light-gray cells, colored border accents.

// Distribute the three tab colors + no-border across 20 cells.
// null = no visible border (dark gap shows through).
const BORDERS: (string | null)[] = [
  null,       '#d86958', null,       '#23349d', null,
  '#23349d',  '#d86958', null,       '#7376c6', '#d86958',
  '#d86958',  null,      '#d86958',  '#23349d', null,
  '#7376c6',  null,      '#23349d',  null,      '#7376c6',
];

const cells = BORDERS.map((border, i) => ({ border, n: i + 1 }));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://use.typekit.net/dzu6izh.css" />
    <title>Archive — Talking Around Fire</title>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;Now we have to edit
      }

      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
        background: #000;
      }

      /* ── Full-screen shell ── */
      .archive-page {
        height: 100vh;
        background: #000;
        display: flex;
        flex-direction: column;
        padding: 3rem 12.5% 2rem;
        gap: 6rem;
      }

      /* ── Navigation tabs — right-aligned ── */
      .archive-nav {
        display: flex;
        flex-direction: row;
        justify-content: flex-end;
        align-items: center;
        gap: 2.2rem;
        flex-shrink: 0;
      }

      .archive-tab {
        display: block;
        padding: 0;
        font-family: 'bebas-neue-pro', 'Bebas Neue Pro', 'Arial Narrow', sans-serif;
        font-size: 0.8rem;
        font-weight: 400;
        letter-spacing: 0.12em;
        text-decoration: none;
        color: #ffffff;
        text-transform: uppercase;
        transition: opacity 0.15s ease;
      }

      .archive-tab:hover { opacity: 0.72; }

      /* ── Grid ── */
      .archive-grid {
        flex: 1;
        min-height: 0;
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        grid-template-rows: repeat(4, 1fr);
        gap: 10px;
      }

      /* ── Cell ── */
      .archive-cell {
        background: #e9e9e9;
      }
    </style>
  </head>
  <body>

    <div class="archive-page">

      <nav class="archive-nav" aria-label="Section navigation">
        <a href="/timeline"       class="archive-tab tab-policy">_Planning &amp; Policy</a>
        <a href="/alerts"         class="archive-tab tab-forestry">_112 Alerts</a>
        <a href="#"               class="archive-tab tab-forestry">_Forestry Service</a>
        <a href="/home"           class="archive-tab tab-hybrid">_Hybrid Schemes</a>
      </nav>

      <div class="archive-grid">
        {cells.map(cell => (
          <div
            class="archive-cell"
            style={cell.border ? `--cb:${cell.border}` : ''}
          ></div>
        ))}
      </div>

    </div>

  </body>
</html>
