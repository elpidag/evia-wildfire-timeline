---
// Archive — Talking Around Fire
// Centered navigation menu on dark background.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://use.typekit.net/dzu6izh.css" />
    <title>Archive — Talking Around Fire</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
        background: #000;
      }

      .archive-page {
        height: 100vh;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .archive-menu {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2.4rem;
      }

      .archive-link {
        font-family: 'bebas-neue-pro', 'Bebas Neue Pro', 'Arial Narrow', sans-serif;
        font-size: 1.4rem;
        font-weight: 400;
        letter-spacing: 0.14em;
        text-decoration: none;
        color: #ffffff;
        text-transform: uppercase;
        transition: opacity 0.15s ease;
      }

      .archive-link:hover {
        opacity: 0.65;
      }
    </style>
  </head>
  <body>
    <div class="archive-page">
      <nav class="archive-menu" aria-label="Section navigation">
        <a href="/alerts" class="archive-link">_Planning &amp; Policy</a>
        <a href="#" class="archive-link">_Forestry Service</a>
        <a href="/home" class="archive-link">_Hybrid Schemes</a>
      </nav>
    </div>

    <script>
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') {
          window.location.href = '/alerts';
        }
      });
    </script>
  </body>
</html>
