---
import BaseLayout from '../layouts/BaseLayout.astro';
import AlertsReplayModule from '../components/alerts/AlertsReplayModule';
import { alerts } from '../lib/alerts/data';
---

<BaseLayout
  title="112 Alerts | Evia Wildfire Timeline"
  description="Chronological replay of 112 emergency evacuation alerts during the August 2021 Greek wildfires."
>
  <div class="alerts-page">
    <header class="alerts-header">
      <div class="alerts-header__left">
        <p class="alerts-header__eyebrow">112 Emergency Alerts</p>
        <h1 class="alerts-header__title">Evacuation Orders</h1>
        <p class="alerts-header__subtitle">August 2021</p>
      </div>
      <nav class="timeline-nav" aria-label="Section navigation">
        <a href="/timeline" class="timeline-nav-tab is-active">_Planning &amp; Policy</a>
        <a href="#" class="timeline-nav-tab">_Forestry Service</a>
        <a href="/home" class="timeline-nav-tab">_Hybrid Schemes</a>
      </nav>
    </header>

    <div class="alerts-workspace">
      <AlertsReplayModule client:load alerts={alerts} />
    </div>
  </div>

  <script>
    function setupAlertsClick() {
      const handler = (e: MouseEvent) => {
        const target = e.target as HTMLElement;
        if (
          target.closest('.maplibregl-map') ||
          target.closest('.maplibregl-canvas-container') ||
          target.closest('canvas') ||
          target.closest('[class*="AlertsTimeline"]') ||
          target.closest('[class*="AlertDetail"]') ||
          target.closest('button') ||
          target.closest('a') ||
          target.closest('input') ||
          target.closest('label') ||
          target.closest('.alerts-header')
        ) return;
        window.location.href = '/timeline';
      };
      document.addEventListener('click', handler);
      document.addEventListener('astro:before-swap', () => {
        document.removeEventListener('click', handler);
      }, { once: true });
    }
    setupAlertsClick();
    document.addEventListener('astro:page-load', () => {
      if (document.body.dataset.navLeft === '/archive') setupAlertsClick();
    });
  </script>
  <script is:inline>document.body.dataset.navLeft = '/archive';</script>
  <script>
    // Eagerly prefetch timeline data while user is on alerts page
    import { fetchTimelineResources } from '@/lib/timeline';
    fetchTimelineResources().catch(() => {});
  </script>
</BaseLayout>

<style is:global>
  .site-shell {
    width: min(100%, 1440px);
    padding: clamp(1.6rem, 2vw, 2.4rem) clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 2vw, 2rem);
  }
</style>
<style>
  .alerts-page {
    --alert-red: #c74949;
    --alert-blue: #3a6fb5;
  }

  .alerts-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    padding: clamp(1rem, 2vw, 1.6rem) 0;
    border-bottom: 2px solid var(--color-text);
    margin-bottom: 0;
  }

  .alerts-header .timeline-nav {
    margin-bottom: 0;
    padding-bottom: 0.2rem;
  }

  .alerts-header__eyebrow {
    margin: 0 0 0.3rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--alert-red);
    font-weight: 600;
  }

  .alerts-header__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 0.92;
    color: var(--color-text);
  }

  .alerts-header__subtitle {
    margin: 0.15rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.5rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    line-height: 1;
  }

  .alerts-workspace {
    margin-top: 0;
  }

  @media (max-width: 640px) {
    .alerts-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
