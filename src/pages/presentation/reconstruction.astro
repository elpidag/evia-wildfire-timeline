---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncedProjectsDeck from '../../components/evoia-meta/AnnouncedProjectsDeck';
import { evoiaMetaProjects } from '../../lib/evoia-meta/data';
---

<BaseLayout
  title="Presentation | Reconstruction | Evia Wildfire Timeline"
  description="Presentation deck for announced Evia Meta reconstruction projects."
>
  <nav class="timeline-nav" aria-label="Section navigation">
    <a href="/timeline" class="timeline-nav-tab">_Planning &amp; Policy</a>
    <a href="#" class="timeline-nav-tab">_Forestry Service</a>
    <a href="/home" class="timeline-nav-tab">_Hybrid Schemes</a>
  </nav>

  <div class="presentation-deck-wrap">
    <AnnouncedProjectsDeck client:only="react" projects={evoiaMetaProjects} />
  </div>

  <style is:global>
    body {
      overflow: hidden;
    }
  </style>

  <style>
    .presentation-deck-wrap {
      height: calc(100vh - 8rem);
      min-height: 20rem;
    }
  </style>
</BaseLayout>
