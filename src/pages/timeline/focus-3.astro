---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineWorkspace from '../../components/timeline/TimelineWorkspace.tsx';
---

<BaseLayout title="Timeline Focus 3 | Evia Wildfire Timeline">
  <nav class="timeline-nav" aria-label="Section navigation">
    <a href="/timeline" class="timeline-nav-tab is-active">_Planning &amp; Policy</a>
    <a href="#" class="timeline-nav-tab">_Forestry Service</a>
    <a href="/home" class="timeline-nav-tab">_Hybrid Schemes</a>
  </nav>
  <TimelineWorkspace client:load focusDomain={['2021-07-20', '2023-10-02']} />

  <script>
    document.addEventListener('keydown', (e) => {
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement).closest('.timeline-host')) return;
      if (e.key === 'ArrowRight') {
        window.location.href = '/presentation/reconstruction';
      }
      if (e.key === 'ArrowLeft') {
        window.location.href = '/timeline/focus-2';
      }
    });
  </script>
</BaseLayout>
