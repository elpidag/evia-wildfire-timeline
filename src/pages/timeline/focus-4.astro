---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineWorkspace from '../../components/timeline/TimelineWorkspace.tsx';
---

<BaseLayout title="Timeline Focus 4 | Evia Wildfire Timeline">
  <nav class="timeline-nav" aria-label="Section navigation">
    <a href="/timeline" class="timeline-nav-tab">_Planning &amp; Policy</a>
    <a href="#" class="timeline-nav-tab is-active">_Forestry Service</a>
    <a href="/home" class="timeline-nav-tab">_Hybrid Schemes</a>
  </nav>

  <div class="focus4-layout">
    <div class="focus4-photo-area">
      <img src="/images/focus4-map.JPG" alt="Map of North Evia forestry zones" class="focus4-photo" />
    </div>
    <div class="focus4-timeline-wrap">
      <TimelineWorkspace
        client:load
        focusDomain={['1965-01-01', '2026-03-16']}
        highlightedIds={[
          'evia-1979-fek-289a',
          'evia-1986-fek-44a',
          'evia-1998-fek-112a',
          'evia-2012-legislation-changes-regarding-forestry',
          'evia-2024-fek-63a',
        ]}
        displayOptions={{
          hideLabels: true,
          hideFireSeasons: true,
          hideFireEvents: true,
          hideDurationEvents: true,
          allPointsOnDivider: true,
          pointsAboveDivider: true,
          solidYearMultiple: 5,
          compactTimelineHeight: 80,
          legendCategories: ['legislation', 'forestry-policy', 'major-political-event'],
          legendAbove: true,
        }}
      />
    </div>
  </div>

  <style is:global>
    html, body {
      overflow: hidden !important;
      height: 100vh !important;
    }
  </style>
  <style>
    .focus4-layout {
      display: flex;
      flex-direction: column;
      height: calc(100vh - 4rem);
      overflow: hidden;
    }
    .focus4-photo-area {
      flex: 1 1 0;
      min-height: 0;
      display: flex;
      justify-content: flex-end;
      align-items: flex-start;
      padding: 0;
    }
    .focus4-photo {
      max-height: 100%;
      max-width: 55%;
      object-fit: contain;
    }
    .focus4-timeline-wrap {
      transform: translateY(-80px);
    }
    .focus4-timeline-wrap :global(.timeline-workspace) {
      height: auto;
      min-height: 0;
    }
    .focus4-timeline-wrap :global(.timeline-bottom-row) {
      padding-left: 26px;
      padding-right: 18px;
      gap: var(--space-3);
    }
    .focus4-timeline-wrap :global(.timeline-bottom-row .event-detail-card) {
      flex: 1 1 0;
      width: auto;
    }
  </style>

  <script is:inline>document.body.dataset.navLeft = '/presentation/reconstruction';</script>
</BaseLayout>