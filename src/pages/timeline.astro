---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineWorkspace from '../components/timeline/TimelineWorkspace.tsx';
---

<BaseLayout title="Timeline | Evia Wildfire Timeline">
  <section class="page-intro">
    <p class="eyebrow">Timeline Workspace</p>
    <h1>Long-range event timeline</h1>
    <p>
      Custom D3 timeline engine with zoom, pan, category lanes, typed filters, synchronized detail interpretation, and
      a subdued spatial map view.
    </p>
  </section>
  <TimelineWorkspace client:load />
</BaseLayout>
