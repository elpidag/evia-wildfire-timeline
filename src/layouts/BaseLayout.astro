---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Evia Wildfire Timeline research archive.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://use.typekit.net/dzu6izh.css" />
    <title>{title}</title>
  </head>
  <body>
    <main class="site-shell">
      <slot />
    </main>
  </body>
</html>
